{
  "name": "noam-spotify-apple",
  "version": "1.0.0",
  "private": true,
  "description": "Native iOS shell for Noam Music (CarPlay + App Store). Does not replace the Vercel PWA.",
  "scripts": {
    "build:web": "bash scripts/sync-from-web.sh",
    "cap:sync": "npm run build:web && npx cap sync ios",
    "cap:open": "npx cap open ios",
    "cap:add-ios": "npx cap add ios"
  },
  "dependencies": {
    "@capacitor/app": "^7.0.1",
    "@capacitor/core": "^7.2.0",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/splash-screen": "^7.0.1",
    "@capacitor/status-bar": "^7.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.2.0",
    "typescript": "^5.8.3"
  }
}
