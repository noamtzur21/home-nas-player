PORT=3001
PUBLIC_BACKEND_URL=http://localhost:3001
CACHE_DIR=./cache

# Required on Render/cloud — export Netscape cookies from browser (see yt-dlp wiki)
# Option A: base64-encoded cookies.txt content
# YT_DLP_COOKIES=
# Option B: path to cookies file (Render Secret File → /etc/secrets/cookies.txt)
# YT_DLP_COOKIES_FILE=/etc/secrets/cookies.txt

ALLOWED_HOSTS=192.168.1.100,nas.local,localhost
