# Streaming runs via /api/stream on Vercel (Piped proxy).
# No external backend or cookies required.

# Cloud backup (Firebase) — single fixed account so every device/install
# reads and writes the same playlists/songs. Not a real "login": the app
# signs in silently with these on startup. Set the same two vars in
# Vercel → Settings → Environment Variables for production.
VITE_FIREBASE_USER_EMAIL=
VITE_FIREBASE_USER_PASSWORD=

# Optional: override API host for native app (defaults to production Vercel URL on iOS).
# VITE_API_BASE_URL=https://your-app.vercel.app
